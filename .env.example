# BrainPal — env template (committed, no real secrets)
# Copy to .env.local for dev. Fill via Secrets Manager / Supabase secrets / EAS in higher envs.

# ─── Supabase (mobile + api + edge fns) ────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=                  # client-safe (mobile reads as EXPO_PUBLIC_SUPABASE_ANON_KEY)
SUPABASE_SERVICE_ROLE_KEY=          # SERVER-ONLY — never bundle in mobile

# ─── Twilio (edge function only) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# ─── AI providers (api server only, Fargate) ──────────────────────────
GEMINI_API_KEY=                     # Gemini 2.0 Flash (perception)
XAI_API_KEY=                        # Grok 4.1 reasoning, OpenAI-compat at https://api.x.ai/v1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=                # "Charlie" (dry British) or "Antoni" (deadpan US) — lock day 1

# ─── Mobile-facing endpoints (set per env in EAS) ─────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_WS_URL=ws://localhost:3000/live
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─── Observability ────────────────────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_MOBILE=

# ─── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
