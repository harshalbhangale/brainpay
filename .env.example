# BrainPal — env template (committed, no real secrets)
# Copy to .env.local for dev. Fill via Secrets Manager / Supabase secrets / EAS in higher envs.

# ─── Supabase (mobile + api + edge fns) ────────────────────────────────
# SUPABASE_URL is the postgres:// connection string for Drizzle.
# SUPABASE_API_URL is the https://*.supabase.co URL for the JS client / auth.
SUPABASE_URL=
SUPABASE_API_URL=
SUPABASE_ANON_KEY=                  # publishable / anon key (sb_publishable_* or eyJ JWT)
SUPABASE_SERVICE_ROLE_KEY=          # SERVER-ONLY — never bundle in mobile

# ─── Twilio (edge function only) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# ─── AI providers (api server only, Fargate) ──────────────────────────
BEDROCK_API_KEY=                    # Bedrock long-term API key (vision)
BEDROCK_REGION=ap-southeast-2
BEDROCK_MODEL_ID=apac.amazon.nova-lite-v1:0
OPENAI_API_KEY=                     # personality LLM
OPENAI_MODEL=gpt-5.4-mini
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=                # "Charlie" (dry British) or "Antoni" (deadpan US)
ELEVENLABS_TUTOR_VOICE_ID=          # warm tutor voice for StudyPal AI Interview (falls back to companion voice)

# ─── Vertex AI — Gemini Live API (real-time camera + voice) ───────────
# Auth via ADC locally (`gcloud auth application-default login`) or the
# Fargate task role in prod. Live API requires location=global.
GOOGLE_CLOUD_PROJECT=                # GCP project id holding the $300 credit
GOOGLE_CLOUD_LOCATION=global
GEMINI_LIVE_MODEL=gemini-live-2.5-flash
VERTEX_LIVE_ENABLED=true

# ─── Mobile-facing endpoints (set per env in EAS) ─────────────────────
EXPO_PUBLIC_API_BASE_URL=https://api.zapfan.com
EXPO_PUBLIC_WS_URL=wss://api.zapfan.com/live
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─── Stripe (payments) ────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=                 # pk_test_... or pk_live_...
STRIPE_SECRET_KEY=                      # SERVER-ONLY — never bundle in mobile
STRIPE_WEBHOOK_SECRET=                  # whsec_... from Stripe dashboard
STRIPE_MERCHANT_ID=merchant.com.brainpal.pay

# Stripe (mobile-facing — safe to bundle, publishable key only)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # same as STRIPE_PUBLISHABLE_KEY
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.com.brainpal.pay

# ─── Google Maps (location / Find My Family) ─────────────────────────
GOOGLE_MAPS_API_KEY=                    # Maps SDK iOS + Android + Geocoding
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=        # same key, exposed to mobile bundle

# ─── Observability ────────────────────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_MOBILE=

# ─── Internal cron ────────────────────────────────────────────────────
# Guards unauthenticated cron endpoints (POST /study/nudge-check) via the
# x-cron-key header. REQUIRED in production. Use a long random value.
CRON_SECRET=

# ─── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
VOICE_ENABLED=true
