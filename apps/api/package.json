{
  "name": "@brainpal/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "seed": "tsx --env-file=../../.env scripts/seed-transactions.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@brainpal/shared": "workspace:*",
    "@google/genai": "^2.8.0",
    "@hono/node-server": "1.14.4",
    "@supabase/supabase-js": "2.46.1",
    "drizzle-orm": "0.36.4",
    "expo-server-sdk": "3.14.0",
    "hono": "4.7.4",
    "jose": "5",
    "openai": "4.103.0",
    "pino": "9.5.0",
    "postgres": "3.4.5",
    "stripe": "17.7.0",
    "ws": "8.18.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@brainpal/config": "workspace:*",
    "@types/node": "22.10.5",
    "@types/ws": "8.5.13",
    "dotenv": "16.4.7",
    "drizzle-kit": "0.28.1",
    "pino-pretty": "13.0.0",
    "tsup": "8.4.0",
    "tsx": "4.19.3",
    "typescript": "5.7.3"
  }
}
