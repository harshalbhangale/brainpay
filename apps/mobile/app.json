{
  "expo": {
    "name": "BrainPal",
    "slug": "brainpal",
    "version": "0.1.0",
    "scheme": "brainpal",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "bundleIdentifier": "tech.brainpal.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "BrainPal uses your camera to scan snacks.",
        "NSMicrophoneUsageDescription": "BrainPal needs the mic only if voice-in is enabled."
      }
    },
    "android": {
      "package": "tech.brainpal.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "BrainPal",
      "shortName": "BrainPal",
      "themeColor": "#0B0B0F",
      "backgroundColor": "#0B0B0F"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BrainPal to access your camera so it can scan snacks."
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "WS_URL": "wss://api.zapfan.com/live"
    },
    "experiments": {
      "reactCompiler": true
    }
  }
}
