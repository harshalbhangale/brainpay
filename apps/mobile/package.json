{
  "name": "@brainpal/mobile",
  "private": true,
  "version": "0.0.0",
  "main": "expo-router/entry",
  "expo": {
    "install": {
      "exclude": [
        "react-native-reanimated"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager",
          "react-native-webrtc"
        ]
      }
    }
  },
  "scripts": {
    "dev": "expo start",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .expo dist",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@brainpal/shared": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "@siteed/audio-studio": "^3.2.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "2.46.1",
    "@tanstack/react-query": "5.62.7",
    "buffer": "6.0.3",
    "canvas-confetti": "^1.9.4",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.0",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.0",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~3.0.0",
    "lottie-react-native": "~7.3.8",
    "lucide-react-native": "^0.475.0",
    "moti": "^0.30.0",
    "phosphor-react-native": "^3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-nfc-manager": "3.14.14",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "2.0.0",
    "react-native-web": "^0.21.2",
    "react-native-webrtc": "124.0.5",
    "react-native-worklets": "0.5.1",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@brainpal/config": "workspace:*",
    "@config-plugins/react-native-webrtc": "^12.0.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.17",
    "typescript": "5.9.3"
  }
}
