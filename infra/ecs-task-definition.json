{
  "family": "brainpal-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/brainpal-api-task-role",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "ACCOUNT_ID.dkr.ecr.ap-southeast-2.amazonaws.com/brainpal-api:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "LOG_LEVEL", "value": "info" }
      ],
      "secrets": [
        { "name": "SUPABASE_URL", "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:ACCOUNT_ID:secret:brainpal/prod/api:SUPABASE_URL::" },
        { "name": "SUPABASE_API_URL", "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:ACCOUNT_ID:secret:brainpal/prod/api:SUPABASE_API_URL::" },
        { "name": "SUPABASE_SERVICE_ROLE_KEY", "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:ACCOUNT_ID:secret:brainpal/prod/api:SUPABASE_SERVICE_ROLE_KEY::" },
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:ACCOUNT_ID:secret:brainpal/prod/api:OPENAI_API_KEY::" },
        { "name": "ELEVENLABS_API_KEY", "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:ACCOUNT_ID:secret:brainpal/prod/api:ELEVENLABS_API_KEY::" },
        { "name": "ELEVENLABS_VOICE_ID", "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:ACCOUNT_ID:secret:brainpal/prod/api:ELEVENLABS_VOICE_ID::" },
        { "name": "SENTRY_DSN_API", "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:ACCOUNT_ID:secret:brainpal/prod/api:SENTRY_DSN_API::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/brainpal-api",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "api"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"fetch('http://localhost:3000/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\""],
        "interval": 15,
        "timeout": 3,
        "retries": 3,
        "startPeriod": 10
      }
    }
  ]
}
